# .env.example — copy this to .env and fill in your values
# Never commit .env to source control.

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Flask environment: development | production
FLASK_ENV=development

# Database URL (leave blank to use SQLite in development)
# DATABASE_URL=postgresql://user:password@localhost:5432/videocall

# Port (default 5000)
# PORT=5000

# Allowed CORS origins for SocketIO (comma-separated, or * for all)
# CORS_ORIGINS=https://yourdomain.com

# ---------------------------------------------------------------------------
# Flask-Mail  (required for parent-approval emails in kid registration flow)
# Without these, tokens are printed to the console in dev mode.
# ---------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USERNAME=
MAIL_PASSWORD=          # use a Gmail App Password, not your real password
MAIL_DEFAULT_SENDER=
MAIL_SUPPRESS_SEND=false                 # set true to skip sending and print to console

# ---------------------------------------------------------------------------
# Google AI Studio — Gemini (for the in-call AI assistant)
# Get your key at: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Transcription backend
# ---------------------------------------------------------------------------
# assemblyai (recommended): managed real-time-friendly STT API
# gemini: uses Gemini API and GOOGLE_API_KEY quota
TRANSCRIBE_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=faac0478544c4b18be1f62b25edf12f3
# Example models: universal-2, universal, best, nano, slam-1
ASSEMBLYAI_SPEECH_MODEL=universal-2
# Optional language code (leave empty for auto). Example: en_us
ASSEMBLYAI_LANGUAGE_CODE=
ASSEMBLYAI_FILTER_PROFANITY=true